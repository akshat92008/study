{
  "crons": [
    {
      "path": "/api/cron/daily-synthesis",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/recover-events",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/retry-pending-events",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * 0"
    }
  ]
}
