# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Providers (at least one required)
CEREBRAS_API_KEY=your_cerebras_key_here
GROQ_API_KEY=your_groq_key_here
SAMBANOVA_API_KEY=your_sambanova_key_here
CLOUDFLARE_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/your-account/your-gateway
CLOUDFLARE_API_TOKEN=your_cloudflare_token_here
# CRITICAL: Replace this placeholder or Google provider won't work
GEMINI_API_KEY=your_real_gemini_key_here

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Embeddings — set to false in production
DISABLE_EMBEDDINGS=false

# Stripe (leave as dummy until billing is implemented)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PRICE_ID=price_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0
CRON_SECRET=generate_a_random_32_char_string_here

# Monitoring (optional — leave empty to disable)
SENTRY_DSN=                      # server-side error tracking
NEXT_PUBLIC_SENTRY_DSN=          # client-side error tracking (same DSN, ok to expose)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS={}
