# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Providers (at least one required)
CEREBRAS_API_KEY=your_cerebras_key_here
GROQ_API_KEY=your_groq_key_here
SAMBANOVA_API_KEY=your_sambanova_key_here
CLOUDFLARE_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/your-account/your-gateway
CLOUDFLARE_API_TOKEN=your_cloudflare_token_here
# CRITICAL: Replace this placeholder or Google provider won't work
GEMINI_API_KEY=your_real_gemini_key_here

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Embeddings — set to false in production
DISABLE_EMBEDDINGS=false

# Stripe is intentionally disabled for the controlled beta.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PRICE_ID=price_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0
INTERNAL_CRON_SECRET=generate_a_random_32_plus_char_string_here
INTERNAL_WORKER_SECRET=generate_a_different_random_32_plus_char_string_here
WORKER_SECRET=generate_a_different_random_32_plus_char_string_here
# CRON_SECRET=generate_a_random_32_char_string_here # legacy fallback only

# Manual beta access
PAID_BETA_GATE_ENABLED=true
MANUAL_BETA_ACCESS_ONLY=true
PUBLIC_BETA_MODE=true
REQUIRE_INVITE_CODE=true
MAX_BETA_USERS=300
BETA_INVITE_CODES=
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Beta kill switches
AI_GLOBAL_KILL_SWITCH=false
RAG_UPLOADS_ENABLED=true
RAG_QUERIES_ENABLED=true
AUTOPSY_UPLOADS_ENABLED=true
AUTOPSY_REPORTS_ENABLED=true
HERMES_WRITES_ENABLED=true
WORKER_AI_ENABLED=false
BACKGROUND_JOBS_ENABLED=true
SESSION_CARD_ENABLED=true
REVISION_ENABLED=true
ATLAS_ENABLED=true
DEBUG_PAGES_ENABLED=false

# Global beta safety budgets
GLOBAL_DAILY_AI_BUDGET_USD=8
GLOBAL_HOURLY_AI_REQUEST_LIMIT=300
GLOBAL_DAILY_AI_REQUEST_LIMIT=2500
GLOBAL_AUTOPSY_REPORTS_PER_DAY=200
GLOBAL_RAG_UPLOADS_PER_DAY=150
GLOBAL_CHAT_MESSAGES_PER_DAY=4000
GLOBAL_MAX_ACTIVE_USERS_PER_DAY=120

# Manual plan chat caps
FREE_DAILY_CHAT_LIMIT=3
FOUNDING_DAILY_CHAT_LIMIT=40
PRO_DAILY_CHAT_LIMIT=80

# Event worker beta caps
EVENT_WORKER_BATCH_SIZE=25
EVENT_WORKER_MAX_DURATION_MS=20000
EVENT_MAX_RETRY_ATTEMPTS=3
EVENT_LOCK_TTL_SECONDS=120

# Hermes Lite
HERMES_ENABLED=true
HERMES_MODE=lite
HERMES_SOURCE_PROCESSING_ENABLED=false
HERMES_TRACE_ENABLED=false
HERMES_NEXT_ACTION_ENABLED=false
HERMES_CODING_SANDBOX_ENABLED=false
HERMES_AGENT_LOOP_ENABLED=false

# Monitoring (CRITICAL: SENTRY_DSN is required in production for observability)
SENTRY_DSN=your_real_sentry_dsn_here                      # server-side error tracking
NEXT_PUBLIC_SENTRY_DSN=your_real_sentry_dsn_here          # client-side error tracking (same DSN, ok to expose)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS={}
