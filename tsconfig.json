{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/db/*": [
        "./lib/db/*"
      ],
      "@/services/*": [
        "./lib/services/*"
      ],
      "@/graph/*": [
        "./lib/graph/*"
      ],
      "@/telemetry/*": [
        "./lib/telemetry/*"
      ],
      "@/alerts/*": [
        "./lib/alerts/*"
      ],
      "@/workers/*": [
        "./lib/workers/*"
      ],
      "@/planners/*": [
        "./lib/planners/*"
      ],
      "@/queues/*": [
        "./lib/queues/*"
      ],
      "@/engines/*": [
        "./lib/engines/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scratch"
  ]
}
