{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/db/*": [
        "./lib/db/*"
      ],
      "@/services/*": [
        "./lib/services/*"
      ],
      "@/graph/*": [
        "./lib/graph/*"
      ],
      "@/telemetry/*": [
        "./lib/telemetry/*"
      ],
      "@/alerts/*": [
        "./lib/alerts/*"
      ],
      "@/workers/*": [
        "./lib/workers/*"
      ],
      "@/planners/*": [
        "./lib/planners/*"
      ],
      "@/queues/*": [
        "./lib/queues/*"
      ],
      "@/engines/*": [
        "./lib/engines/*"
      ],
      "@supabase/ssr": [
        "./types/supabase-ssr-shim.d.ts"
      ],
      "@supabase/supabase-js": [
        "./types/supabase-js-shim.d.ts"
      ],
      "zustand": [
        "./types/zustand-shim.d.ts"
      ],
      "zustand/middleware": [
        "./types/zustand-shim.d.ts"
      ],
      "framer-motion": [
        "./types/framer-motion-shim.d.ts"
      ],
      "recharts": [
        "./types/recharts-shim.d.ts"
      ],
      "@xyflow/react": [
        "./types/xyflow-react-shim.d.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scratch",
    ".next/dev",
    "temp_neetapp",
    "tests",
    "__tests__",
    "scripts",
    "*.config.ts"
  ]
}
