NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
# Cloudflare Workers AI
CF_API_TOKEN=
CF_ACCOUNT_ID=
# Legacy aliases also supported:
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated list of admin emails
ADMIN_EMAILS=

# Worker / Cron
INTERNAL_CRON_SECRET=generate_a_random_32_plus_char_string_here
INTERNAL_WORKER_SECRET=generate_a_different_random_32_plus_char_string_here
# CRON_SECRET= # legacy fallback only
EVENT_WORKER_BATCH_SIZE=25
EVENT_WORKER_LEASE_MINUTES=5
EVENT_WORKER_MAX_ATTEMPTS=5
EVENT_WORKER_MAX_RUNTIME_MS=50000
EVENT_COALESCE_WINDOW_SECONDS=120
DAILY_USER_EVENT_LIMIT=500

# Public beta gate
PUBLIC_BETA_MODE=true
REQUIRE_INVITE_CODE=true
MAX_BETA_USERS=300
BETA_INVITE_CODES=

# Feature flags / beta kill switches
ENABLE_VISION_UPLOADS=false
ENABLE_RAG_INGESTION=true
ENABLE_AUTOPSY_PROCESSING=true
ENABLE_AGENT_ACTIONS=false
ENABLE_AI_ESCALATION=true

# AI budget controls
AI_DAILY_BUDGET_USD=1
AI_HOURLY_BUDGET_USD=0.2
AI_PER_USER_DAILY_BUDGET_USD=0.05
DAILY_USER_AI_REQUEST_LIMIT=30
DAILY_GLOBAL_AI_REQUEST_LIMIT=1000

# Optional cheap mode
DISABLE_EMBEDDINGS=false
NODE_ENV=development

# Cheap-First AI Mode
AI_COST_MODE=ultra_cheap
ENABLE_PAID_AI_FALLBACK=false
ENABLE_ANTHROPIC_AI=false
ENABLE_GOOGLE_AI=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MAX_CHAT_INPUT_TOKENS=2200
MAX_CHAT_OUTPUT_TOKENS=450
MAX_AI_INPUT_CHARS=12000
MAX_AI_OUTPUT_TOKENS=500
MAX_RAG_CHUNKS=3
MAX_RECENT_MESSAGES=3
MAX_CHAT_HISTORY_MESSAGES=6
ENABLE_AI_RESPONSE_CACHE=true
ENABLE_RULE_FIRST_RESPONDER=true
ENABLE_DB_PROVIDER_COOLDOWNS=true
MAX_SYNC_MCQ_COUNT=10
MAX_SYNC_FLASHCARD_COUNT=15
MAX_SYNC_MOCK_TEST_QUESTIONS=20

# Source/RAG upload caps
RAG_MAX_FILE_MB=10
RAG_MAX_FILES_PER_USER=5
RAG_MAX_DAILY_UPLOADS=5
RAG_MAX_CHUNKS_PER_FILE=40

# Deep Autopsy V3
AUTOPSY_V3_ENABLED=true
AUTOPSY_MAX_PDF_MB=5
AUTOPSY_MAX_QUESTIONS_PER_ASSESSMENT=200
AUTOPSY_MAX_AI_MISTAKES_PER_BATCH=25
AUTOPSY_MAX_REPORT_TOKENS=1200
AUTOPSY_DAILY_ASSESSMENTS_PER_USER=3
AUTOPSY_DAILY_PDF_UPLOADS_PER_USER=2
AUTOPSY_DAILY_REPORTS_PER_USER=3
AUTOPSY_EXPERIMENTAL_OCR_ENABLED=false
HERMES_AUTOPSY_V3_ENABLED=true
HERMES_AUTOPSY_V3_MODE=lite
HERMES_AUTOPSY_MAX_MEMORY_WRITES_PER_REPORT=10
HERMES_AUTOPSY_MAX_REMINDERS=3
