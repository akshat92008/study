ENABLE_RAG_INGESTION=true
ENABLE_AUTOPSY_PROCESSING=true
ENABLE_AGENT_ACTIONS=false
ENABLE_AI_ESCALATION=true
AI_GLOBAL_KILL_SWITCH=false
RAG_UPLOADS_ENABLED=true
RAG_QUERIES_ENABLED=true
AUTOPSY_UPLOADS_ENABLED=true
AUTOPSY_REPORTS_ENABLED=true
HERMES_WRITES_ENABLED=true
WORKER_AI_ENABLED=false
BACKGROUND_JOBS_ENABLED=true
SESSION_CARD_ENABLED=true
REVISION_ENABLED=true
ATLAS_ENABLED=true
DEBUG_PAGES_ENABLED=false

# AI budget controls (alpha-safe: 5–20 users)
AI_DAILY_BUDGET_USD=1
AI_HOURLY_BUDGET_USD=0.2
AI_PER_USER_DAILY_BUDGET_USD=0.05
DAILY_USER_AI_REQUEST_LIMIT=60
DAILY_GLOBAL_AI_REQUEST_LIMIT=300
