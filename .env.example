# Worker / Cron (alpha-safe defaults)
INTERNAL_CRON_SECRET=generate_a_random_32_plus_char_string_here
INTERNAL_WORKER_SECRET=generate_a_different_random_32_plus_char_string_here
WORKER_SECRET=generate_a_different_random_32_plus_char_string_here
# CRON_SECRET= # legacy fallback only
