FREE_DAILY_CHAT_LIMIT=3
FREE_HOURLY_CHAT_LIMIT=10
FOUNDING_DAILY_CHAT_LIMIT=40
PRO_DAILY_CHAT_LIMIT=80

# Optional cheap mode
DISABLE_EMBEDDINGS=false
NODE_ENV=development

# Cheap-First AI Mode
