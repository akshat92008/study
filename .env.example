EVENT_WORKER_CONCURRENCY=2
EVENT_WORKER_LEASE_MINUTES=5
EVENT_WORKER_MAX_ATTEMPTS=5
EVENT_WORKER_MAX_RUNTIME_MS=30000
EVENT_WORKER_MAX_DURATION_MS=20000
EVENT_MAX_RETRY_ATTEMPTS=3
EVENT_LOCK_TTL_SECONDS=120
EVENT_COALESCE_WINDOW_SECONDS=300
DAILY_USER_EVENT_LIMIT=100
DRAIN_MAX_BATCHES=20

# Public beta gate
PUBLIC_BETA_MODE=true
REQUIRE_INVITE_CODE=true
MAX_BETA_USERS=300
BETA_INVITE_CODES=
PAID_BETA_GATE_ENABLED=true
MANUAL_BETA_ACCESS_ONLY=true

# Feature flags / beta kill switches
# PULSE is intentionally excluded from MVP — do not add ENABLE_PULSE here
ENABLE_VISION_UPLOADS=false
