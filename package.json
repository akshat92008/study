{
  "name": "cognition-os",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "typecheck:full": "tsc --noEmit --project tsconfig.typecheck.json",
    "type-check": "tsc --noEmit --project tsconfig.typecheck.json",
    "verify:beta-launch": "npm ci && npm run typecheck:full && npm run lint && npm test && npm run build && npm run schema:check",
    "ci:type-check": "node scripts/checkTypeTime.js",
    "audit:db": "node scripts/auditDbCalls.js",
    "audit:schema": "node scripts/auditDbCalls.js",
    "test": "vitest run",
    "test:access": "vitest run tests/access",
    "test:limits": "vitest run tests/limits",
    "test:paid-beta": "vitest run tests/paid-beta",
    "test:ownership": "vitest run tests/ownership",
    "test:autopsy": "vitest run tests/autopsy-v3 tests/autopsy",
    "test:worker": "vitest run tests/worker.test.ts tests/workers tests/events/event-worker.test.ts tests/events/workerRouteAuth.test.ts",
    "test:mvp": "vitest run __tests__/integration/mvp-smoke.test.ts __tests__/integration/autopsy-pipeline.test.ts __tests__/integration/autopsy-event-loop.test.ts tests/integration/coreLoop.test.ts tests/integration/mvpLocalLoop.test.ts tests/contracts/noSchemaDrift.test.ts tests/rls.test.ts tests/events/autopsyEvidence.test.ts tests/workers/eventWorker.test.ts tests/workers/eventWorkerChatSideEffects.test.ts tests/chat/chatPersistence.test.ts",
    "test:watch": "vitest",
    "verify:agentic-loop": "NODE_OPTIONS='-r ./scripts/mock-server-only.js' tsx scripts/verify-agentic-loop.ts",
    "test:integration": "vitest --project integration",
    "test:coverage": "vitest --coverage",
    "evals": "node scripts/run-evals.js",
    "preflight:env": "ts-node scripts/env-preflight.ts",
    "smoke:mvp": "ts-node scripts/mvp-smoke-check.ts",
    "smoke:manual-beta": "tsx scripts/smoke-manual-beta.ts",
    "smoke:agentic": "ts-node scripts/agentic-smoke-check.ts",
    "smoke:beta100": "ts-node scripts/beta100-smoke-check.ts",
    "smoke:beta10": "tsx scripts/beta-smoke-check.ts",
    "preflight:beta": "tsx scripts/preflight-beta.ts",
    "beta100:cheap-test": "npx tsx scripts/beta100-load-test.ts",
    "alpha10:smoke": "tsx scripts/alpha10-smoke-test.ts",
    "verify:schema": "ts-node scripts/verify-schema.ts",
    "schema:check": "ts-node scripts/schema-sanity-check.ts",
    "schema:rls:beta": "tsx scripts/verify-rls-beta.ts",
    "schema:beta-contract": "tsx scripts/schema-beta-contract.ts",
    "contract:check": "ts-node scripts/check-schema-contract.ts",
    "verify:local": "SKIP_ENV_VALIDATION=1 npm run typecheck && npm run lint && npm test && npm run build && SKIP_ENV_VALIDATION=1 npm run smoke:mvp -- --mode=local",
    "verify:db": "npx tsx scripts/verify-db.ts",
    "verify:production": "NODE_ENV=production ts-node scripts/env-preflight.ts --mode=production && npm run typecheck && npm run lint && npm test && npm run build",
    "verify:mvp": "npm run verify:production && ts-node scripts/mvp-smoke-check.ts -- --mode=mvp",
    "verify:beta": "npm run typecheck && npm run lint && npm run test && npm run build",
    "verify:public-launch": "npm ci && npm run preflight:env -- --mode=public_paid && npm run typecheck && npm run lint && npm test && npm run build && npm run schema:check",
    "launch:manual-beta-local": "npm run typecheck && npm run lint && npm test && npm run build && npm run test:autopsy && npm run test:worker && npm run schema:beta-contract && npm run schema:rls:beta && npm run schema:check && npm run smoke:manual-beta",
    "launch:manual-beta-remote": "if [ -z \"$SUPABASE_URL\" ] || [[ \"$SUPABASE_URL\" == *\"127.0.0.1\"* ]] || [[ \"$SUPABASE_URL\" == *\"localhost\"* ]]; then echo 'Error: SUPABASE_URL must be a remote URL'; exit 1; fi && npm run typecheck && npm run lint && npm test && npm run build && npm run test:autopsy && npm run test:worker && npm run schema:beta-contract && npm run schema:rls:beta && npm run schema:check && npm run smoke:manual-beta",
    "seed:mvp": "ts-node scripts/seed-mvp-demo.ts",
    "debug:events": "ts-node scripts/debug-events.ts",
    "debug:user": "ts-node scripts/debug-user-mvp-state.ts",
    "supabase:init": "supabase init",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:pull": "supabase db pull",
    "supabase:push": "supabase db push",
    "supabase:migration": "supabase migration new",
    "study-profile:recompute:dry": "tsx scripts/recompute-study-profile.ts",
    "study-profile:recompute:apply": "tsx scripts/recompute-study-profile.ts --apply",
    "verify:core-loop-contracts": "tsx scripts/verify-core-loop-contracts.ts",
    "test:invariants": "vitest run tests/invariants",
    "test:security": "vitest run tests/security tests/rls.test.ts tests/ownership",
    "eval:mind": "vitest run tests/evals/mind-agent.eval.test.ts tests/mind",
    "smoke:core-loop": "tsx scripts/smoke-core-loop.ts",
    "repair:core-loop:dry": "tsx scripts/repair-stuck-core-loop.ts",
    "repair:core-loop": "tsx scripts/repair-stuck-core-loop.ts --repair",
    "report:launch-blockers": "tsx scripts/generate-launch-blockers-report.ts",
    "verify:real-mvp": "npm run typecheck && npm run lint && npm test && npm run verify:core-loop-contracts && npm run test:invariants && npm run eval:mind && npm run smoke:core-loop && npm run schema:check && npm run test:security && npm run build"
  },
